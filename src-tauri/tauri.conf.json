{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Maataa OS",
  "version": "0.1.0-alpha.1",
  "identifier": "in.tlps.maataaos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Maataa OS",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
