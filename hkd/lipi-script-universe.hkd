  "claims": [
    { "id":"c-scripts-mapped-1248","text":"Scripts Mapped: 1,248+","status":"PARTIAL","blockedReason":"lipi-runtime declares a 426-slot script registry (per its README). 1,248 is not derivable from the package; possibly aspirational expansion.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-status","confidence":0.90 },
    { "id":"c-living-scripts-54","text":"Living Scripts: 54+","status":"PARTIAL","blockedReason":"Real living scripts on Earth — broadly accurate as a count of currently-used writing systems. Whether the lipi-runtime registry implements all is unverified.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-status","confidence":0.80 },
    { "id":"c-extinct-scripts-312","text":"Extinct Scripts: 312+","status":"PARTIAL","blockedReason":"Order-of-magnitude plausible for known extinct scripts. lipi-runtime would need to enumerate them.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-status","confidence":0.80 },
    { "id":"c-glyphs-54-21k","text":"Glyphs & Symbols: 54.21K+","status":"PARTIAL","blockedReason":"Unicode 15 contains ~149,000 characters; 54K is a plausible subset. lipi-runtime doesn't yet expose a glyph count.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-status","confidence":0.85 },
    { "id":"c-scholars-3842","text":"Script Scholars: 3,842+","status":"BLOCKED","blockedReason":"No scholar registry.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-status","confidence":0.99 },
    { "id":"c-manuscripts-12-87m","text":"Manuscripts Cataloged: 12.87M+","status":"BLOCKED","blockedReason":"No manuscript catalog in repo.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-status","confidence":0.99 },
    { "id":"c-lipi-impact-94-2","text":"Lipi Impact Dashboard: 94.2/100 (Cultural Preservation 95.6 / Knowledge Accessibility 94.1 / Education 93.8 / Digital Empowerment 94.7 / Community Inclusion 93.0 / Civilizational Continuity 95.3 / Innovation 94.4 / Future Readiness 93.6) + Data Reliability 99.92%","status":"BLOCKED","blockedReason":"Composite + 8 sub-scores fabricated.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-impact-dashboard","confidence":0.99 },
    { "id":"c-7-script-families","text":"7 Major Script Families (Brahmi / Abjad / Abugida / Alphabet / Logographic / Syllabic / Symbolic)","status":"PARTIAL","blockedReason":"Linguistically standard taxonomy. lipi-runtime/src/{characters,registry,lineage,phonetics} provides substrate for at least the Brahmi family. Full coverage of 7 families is aspirational.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-major-families","confidence":0.85 },
    { "id":"c-script-evolution-timeline","text":"Evolution Timeline: Prehistoric → Indus 3300 BCE → Vedic Oral → Brahmi 600 BCE → Gupta 300 CE → Medieval → Digital → AI Future","status":"PARTIAL","blockedReason":"Lineage matches mainstream paleography (with Indus undeciphered, properly marked Research). lipi-runtime/src/lineage models this.","sourceImage":"user-provided/2026-05-28/lipi-script-board.png","sourceSectionId":"sec-evolution-timeline","confidence":0.85 },
