    { "id":"c-maataa-ai-suite-shipped","text":"Maataa AI Suite is a shipping product","status":"BLOCKED","blockedReason":"No 'Maataa AI Suite' bundle exists. AI primitives live inside kbs-runtime (RAG/search) and visual-hkd-runtime (vision pipeline) as packages, not as a customer-installable AI Suite product.","sourceImage":"user-provided/2026-05-28/product-universe-board.png","sourceSectionId":"sec-cat-ai","confidence":0.90 },
    { "id":"c-lipi-product-shipped","text":"A 'LipiMate' or Lipi product is shipping","status":"PARTIAL","blockedReason":"No customer product 'LipiMate' on board, but lipi-runtime exists with publishable manifest (private:false). It is a publishable runtime, not a productized end-user app.","sourceImage":"user-provided/2026-05-28/product-universe-board.png","sourceSectionId":"sec-cat-creation","confidence":0.70 },
