  "claims": [
    { "id":"c-25-worlds-firsts-all","text":"All 25 cards: each described as 'First OS' for its respective claim","status":"BLOCKED","blockedReason":"Every 'World's First' claim is a comparative superlative. PHKD principle 1 (Evidence Before Claims) and 3 (No Fake 100%) require evidence of (a) the underlying capability working and (b) a comparative search establishing no prior art. Neither exists. The phrase 'World's First' on a 25-card board with no benchmark dataset is a categorical violation of the directive.","sourceImage":"user-provided/2026-05-28/worlds-firsts-board.png","sourceSectionId":"sec-firsts","confidence":0.99 },
    { "id":"c-wf-04-lipi-os-first","text":"WF 04: First OS with native multi-script intelligence supporting ancient to modern scripts","status":"PARTIAL","blockedReason":"lipi-runtime is real, with a 426-slot registry and lineage. 'First OS' is unsupported — many OS-level i18n/CLDR/Unicode systems exist; the differentiation needs to be stated precisely (e.g. 'first runtime to register pre-Brahmi → Brahmi → Devanagari lineage as canonical') and benchmarked.","sourceImage":"user-provided/2026-05-28/worlds-firsts-board.png","sourceSectionId":"sec-firsts","confidence":0.92 },
    { "id":"c-wf-05-sovereign-encrypted","text":"WF 05: First OS 100% sovereign, encrypted, and offline-first capable","status":"BLOCKED","blockedReason":"Fake-100% + comparative superlative + no encryption implementation. Triple PHKD violation.","sourceImage":"user-provided/2026-05-28/worlds-firsts-board.png","sourceSectionId":"sec-firsts","confidence":0.99 },
    { "id":"c-wf-10-brahmini-chain","text":"WF 10: First decentralized identity / reputation / ownership protocol built on Brahmini Chain","status":"BLOCKED","blockedReason":"No blockchain implementation. Directive bans 'fake blockchain theatrics'.","sourceImage":"user-provided/2026-05-28/worlds-firsts-board.png","sourceSectionId":"sec-firsts","confidence":0.99 },
    { "id":"c-wf-21-loving-os","text":"WF 21: First OS built with love, values, compassion, and dharma at its core","status":"UNVERIFIED","blockedReason":"Value-laden, not a verifiable engineering property. 'Loving' is not a measurable system attribute.","sourceImage":"user-provided/2026-05-28/worlds-firsts-board.png","sourceSectionId":"sec-firsts","confidence":0.90 }
  ],
