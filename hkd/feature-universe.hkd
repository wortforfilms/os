    { "id":"c-services-500plus","text":"All Services: 500+ Active","status":"BLOCKED","blockedReason":"No live services exist; figure fabricated.","sourceImage":"user-provided/2026-05-28/feature-universe-board.png","sourceSectionId":"sec-status","confidence":0.95 },
    { "id":"c-lipi-features-real","text":"Lipi Features (Brahmi, Kharoshthi, Devanagari, Multi-direction, RTL/LTR/TTB, Custom Fonts, Lipi Learning Engine)","status":"PARTIAL","blockedReason":"lipi-runtime/src/{characters,phonetics,registry,learning,search,governance} implement many of these. Indus Script Research is marked '(Research)' on board image 1 — appropriate.","sourceImage":"user-provided/2026-05-28/feature-universe-board.png","sourceSectionId":"sec-runtime-features","confidence":0.85 },
    { "id":"c-knowledge-features-real","text":"Knowledge Features (Knowledge Graph, Semantic Search, AI Reasoning, Source Attribution, Continuous Learning)","status":"PARTIAL","blockedReason":"kbs-runtime/src/{graph,search,claims,provenance,ingestion} provide the underlying capabilities. 'Continuous Learning' as a runtime is aspirational.","sourceImage":"user-provided/2026-05-28/feature-universe-board.png","sourceSectionId":"sec-runtime-features","confidence":0.80 },
    { "id":"c-sovereign-features-aspiration","text":"Sovereign Features: Data Sovereignty / E2E Encryption / Offline First / No Central Server / User Ownership","status":"UNVERIFIED","blockedReason":"Design intent, not measured. No E2E encryption implementation found. No offline-sync engine. 'No Central Server' is repo-level (no server runs) but that's by absence, not by implemented sovereign topology.","sourceImage":"user-provided/2026-05-28/feature-universe-board.png","sourceSectionId":"sec-runtime-features","confidence":0.85 },
