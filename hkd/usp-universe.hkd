  "claims": [
    { "id":"c-usp-divine-companion","text":"USP 01: Maataa is not just AI, she is a Divine Companion that understands you emotionally, mentally, and spiritually","status":"UNVERIFIED","blockedReason":"Value-laden marketing claim; not a verifiable product property. No 'emotional/mental/spiritual understanding' is a measurable capability yet.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.90 },
    { "id":"c-usp-multimodal-realtime","text":"USP 02: Seamlessly understands voice, gestures, poses, expressions, text, and intentions in real-time","status":"BLOCKED","blockedReason":"No voice / gesture / pose / expression runtimes exist. Real-time multimodal AI is not implemented.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.95 },
    { "id":"c-usp-privacy-by-design","text":"USP 05: 100% sovereign, encrypted, offline-first capable","status":"BLOCKED","blockedReason":"Fake-100% language. No E2E encryption implemented; no sovereign-by-construction enforcement.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.95 },
    { "id":"c-usp-decentralized-brahmini-chain","text":"USP 06: Built on Brahmini Chain decentralized technology","status":"BLOCKED","blockedReason":"No blockchain implementation present in repo. Directive warns against 'fake blockchain theatrics'.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.95 },
    { "id":"c-usp-unified-kg","text":"USP 07: Connects thousands of knowledge sources into one intelligent graph","status":"PARTIAL","blockedReason":"kbs-runtime/src/graph + kbs-graph implement a graph; 'thousands of sources' overclaims current ingestion.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.85 },
    { "id":"c-usp-chakra-aware","text":"USP 08: First OS to integrate Chakra System with AI","status":"BLOCKED","blockedReason":"No chakra runtime; 'first OS' is a comparative claim with no comparative evidence.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.95 },
    { "id":"c-usp-lipi-multi-script","text":"USP 09: World's most advanced multi-lipi engine supporting ancient to modern scripts","status":"PARTIAL","blockedReason":"lipi-runtime is real and substantial. 'World's most advanced' is a comparative superlative unsupported by external benchmarks.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.90 },
    { "id":"c-usp-end-to-end-automation","text":"USP 10: From thinking to execution, Maataa OS automates workflows, tasks, approvals, reminders, and reporting intelligently","status":"BLOCKED","blockedReason":"No automation runtime exists.","sourceImage":"user-provided/2026-05-28/usp-universe-board.png","sourceSectionId":"sec-usps","confidence":0.95 },
